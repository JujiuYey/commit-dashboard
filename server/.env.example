# 数据库环境变量配置示例
# 复制此文件为 .env 并修改为你的实际配置

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=sag_rag
DB_SSLMODE=disable

# Bun 调试模式（开发环境设置为 1，生产环境设置为 0）
BUNDEBUG=1

# MinIO 对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=documents

# 豆包 API 配置
ARK_API_KEY=your_ark_api_key_here
ARK_MODEL=doubao-seed-1-6-251015
ARK_EMBEDDING_MODEL=your_ark_embedding_model_here


# Qdrant 向量数据库配置
QDRANT_URL=http://localhost:6333

# Redis 配置（用于任务队列）
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string

# 默认密码
DEFAULT_PASSWORD=123456